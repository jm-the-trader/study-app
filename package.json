{
  "name": "studyforge",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "StudyForge — a content-driven app to study anything, with lessons and randomized spaced-repetition flashcards. Progress persists to a local SQLite database.",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.0.1",
    "highlight.js": "^11.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.0",
    "vite": "^8.0.16"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  }
}
